# Application
NODE_ENV=development
PORT=3000
API_PREFIX=api
API_VERSION=v1

# MongoDB
MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_USERNAME=
MONGO_PASSWORD=
MONGO_DATABASE=fieldbook

# JWT
JWT_SECRET=
JWT_EXPIRATION=1d
JWT_REFRESH_EXPIRATION=7d

# Throttle
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# Google OAuth
GOOGLE_CLIENT_ID=

# Cloudflare R2 (S3-compatible)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=fieldbook
R2_PUBLIC_URL=

# Mongo Express (dev only)
MONGO_EXPRESS_PORT=8081
